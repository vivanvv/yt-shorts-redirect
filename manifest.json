{
  "manifest_version": 3,
  "name": "YouTube Shorts Redirect",
  "version": "1.0.0",
  "description": "Redirect YouTube Shorts URLs to the normal watch page.",
  "permissions": [
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
